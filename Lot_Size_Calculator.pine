// ═══════════════════════════════════════════════════════════════════════════════
// ██╗      ██████╗ ████████╗    ███████╗██╗███████╗███████╗
// ██║     ██╔═══██╗╚══██╔══╝    ██╔════╝██║╚══███╔╝██╔════╝
// ██║     ██║   ██║   ██║       ███████╗██║  ███╔╝ █████╗
// ██║     ██║   ██║   ██║       ╚════██║██║ ███╔╝  ██╔══╝
// ███████╗╚██████╔╝   ██║       ███████║██║███████╗███████╗
// ╚══════╝ ╚═════╝    ╚═╝       ╚══════╝╚═╝╚══════╝╚══════╝
//         Risk & Lot Size Calculator — Multi-Pair
//       Drag Entry & SL on chart · Partial Close + BE
// ═══════════════════════════════════════════════════════════════════════════════

//@version=5
indicator("Risk & Lot Calculator", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

// Drag these two levels on the chart after adding the indicator
entryPrice = input.price(0, title="📍 Entry Price", confirm=true, group="📐 Trade Setup")
stopPrice  = input.price(0, title="🛑 Stop Loss",   confirm=true, group="📐 Trade Setup")

i_account  = input.float(10000.0, "Balance de Cuenta (USD)", minval=100.0, step=1000.0, group="📐 Trade Setup", tooltip="Balance de tu cuenta de fondeo. Ej: 10000, 25000, 50000, 100000")
i_risk_pct = input.float(1.0, "Riesgo (% del balance)", minval=0.1, maxval=10.0, step=0.5, group="📐 Trade Setup", tooltip="Valores comunes: 0.5%, 1%, 1.5%, 2%")

i_rr_tp1      = input.float(2.0, "Ratio TP1 (R:R)", minval=0.5, step=0.5, group="🎯 Targets & Parciales")
i_rr_tp2      = input.float(3.0, "Ratio TP2 (R:R)", minval=1.0, step=0.5, group="🎯 Targets & Parciales")
i_partial_pct = input.float(80.0, "% a cerrar en TP1", minval=10.0, maxval=100.0, step=5.0, group="🎯 Targets & Parciales")

i_show_zones  = input.bool(true,  "Mostrar zonas coloreadas", group="🎨 Visual")
i_zone_bars   = input.int(15,     "Ancho de zonas (barras)", minval=3, maxval=60, group="🎨 Visual")
i_sl_color    = input.color(#FF1744, "Color SL",  group="🎨 Visual")
i_tp1_color   = input.color(#00E676, "Color TP1", group="🎨 Visual")
i_tp2_color   = input.color(#00B0FF, "Color TP2", group="🎨 Visual")

// ─────────────────────────────────────────────────────────────────────────────
// PAIR AUTO-DETECTION
// ─────────────────────────────────────────────────────────────────────────────

is_jpy_pair = str.contains(syminfo.ticker, "JPY")
is_xau      = str.contains(syminfo.ticker, "XAU")
pip_size    = is_jpy_pair ? 0.01 : is_xau ? 0.10 : 0.0001
pip_value   = is_jpy_pair ? (0.01 / close) * 100000.0 : 10.0
price_fmt   = is_jpy_pair ? "#.###" : is_xau ? "#.##" : "#.#####"

// ─────────────────────────────────────────────────────────────────────────────
// CORE CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────

is_long    = stopPrice < entryPrice
dir_mult   = is_long ? 1.0 : -1.0
sl_pips    = math.abs(entryPrice - stopPrice) / pip_size
risk_usd   = i_account * (i_risk_pct / 100.0)

// Always floor to 1 decimal — never risk more than intended
lot_size   = sl_pips > 0 ? math.floor(risk_usd / (sl_pips * pip_value) * 10) / 10 : 0.0

tp1_price  = entryPrice + dir_mult * sl_pips * i_rr_tp1 * pip_size
tp2_price  = entryPrice + dir_mult * sl_pips * i_rr_tp2 * pip_size

lots_tp1   = lot_size * (i_partial_pct / 100.0)
lots_tp2   = lot_size * (1.0 - i_partial_pct / 100.0)
pips_tp1   = sl_pips * i_rr_tp1
pips_tp2   = sl_pips * i_rr_tp2
profit_tp1 = lots_tp1 * pips_tp1 * pip_value
profit_tp2 = lots_tp2 * pips_tp2 * pip_value

// ─────────────────────────────────────────────────────────────────────────────
// VISUAL — Controlled-width boxes + labels (only on last bar)
// ─────────────────────────────────────────────────────────────────────────────

var box   bx_risk = na
var box   bx_tp1  = na
var box   bx_tp2  = na
var label lb_entry = na
var label lb_sl    = na
var label lb_tp1   = na
var label lb_tp2   = na
var label lb_be    = na

if barstate.islast
    // Clean previous
    box.delete(bx_risk)
    box.delete(bx_tp1)
    box.delete(bx_tp2)
    label.delete(lb_entry)
    label.delete(lb_sl)
    label.delete(lb_tp1)
    label.delete(lb_tp2)
    label.delete(lb_be)

    int box_left  = bar_index - 3
    int box_right = bar_index + i_zone_bars
    int lbl_x     = bar_index + i_zone_bars + 1

    // ── Colored zones ──
    if i_show_zones
        float risk_top = is_long ? entryPrice : stopPrice
        float risk_bot = is_long ? stopPrice  : entryPrice
        bx_risk := box.new(box_left, risk_top, box_right, risk_bot,
             border_color=color.new(i_sl_color, 80), bgcolor=color.new(i_sl_color, 88), border_width=0)

        float tp1_top = is_long ? tp1_price : entryPrice
        float tp1_bot = is_long ? entryPrice : tp1_price
        bx_tp1 := box.new(box_left, tp1_top, box_right, tp1_bot,
             border_color=color.new(i_tp1_color, 85), bgcolor=color.new(i_tp1_color, 90), border_width=0)

        float tp2_top = is_long ? tp2_price : tp1_price
        float tp2_bot = is_long ? tp1_price : tp2_price
        bx_tp2 := box.new(box_left, tp2_top, box_right, tp2_bot,
             border_color=color.new(i_tp2_color, 85), bgcolor=color.new(i_tp2_color, 92), border_width=0)

    // ── Labels ──
    string dir_label = is_long ? "▲ LONG" : "▼ SHORT"
    float profit_total = profit_tp1 + profit_tp2
    float eff_rr = risk_usd > 0 ? profit_total / risk_usd : 0.0

    // Entry: direction + price + lots + risk
    lb_entry := label.new(lbl_x, entryPrice,
         dir_label + " · " + syminfo.ticker +
         "\nEntrada: " + str.tostring(entryPrice, price_fmt) +
         "\nLotaje:  " + str.tostring(lot_size, "#.##") + " lotes" +
         "\nRiesgo:  $" + str.tostring(risk_usd, "#.##") + " (" + str.tostring(i_risk_pct, "#.##") + "%)",
         color=color.new(color.black, 10), textcolor=color.white,
         style=label.style_label_left, size=size.small)

    // SL: price + pips + loss
    lb_sl := label.new(lbl_x, stopPrice,
         "⛔ STOP LOSS" +
         "\n" + str.tostring(stopPrice, price_fmt) + " | -" + str.tostring(sl_pips, "#.#") + " pips" +
         "\nPérdida: -$" + str.tostring(risk_usd, "#.##"),
         color=color.new(i_sl_color, 20), textcolor=color.white,
         style=is_long ? label.style_label_upper_left : label.style_label_lower_left,
         size=size.small)

    // TP1: price + pips + partial lots + profit + BE instruction
    lb_tp1 := label.new(lbl_x, tp1_price,
         "✅ TP1  (1:" + str.tostring(i_rr_tp1, "#.#") + ")" +
         "\n" + str.tostring(tp1_price, price_fmt) + " | +" + str.tostring(pips_tp1, "#.#") + " pips" +
         "\nCerrar: " + str.tostring(lots_tp1, "#.##") + " lotes (" + str.tostring(i_partial_pct, "#") + "%)" +
         "\nGanancia: +$" + str.tostring(profit_tp1, "#.##") +
         "\n→ Mover SL a BE: " + str.tostring(entryPrice, price_fmt),
         color=color.new(i_tp1_color, 20), textcolor=color.white,
         style=is_long ? label.style_label_lower_left : label.style_label_upper_left,
         size=size.small)

    // TP2: price + pips + remaining lots + profit + total summary
    lb_tp2 := label.new(lbl_x, tp2_price,
         "🎯 TP2  (1:" + str.tostring(i_rr_tp2, "#.#") + ")" +
         "\n" + str.tostring(tp2_price, price_fmt) + " | +" + str.tostring(pips_tp2, "#.#") + " pips" +
         "\nMantener: " + str.tostring(lots_tp2, "#.##") + " lotes (" + str.tostring(100 - i_partial_pct, "#") + "%)" +
         "\nGanancia: +$" + str.tostring(profit_tp2, "#.##") +
         "\nTotal: +$" + str.tostring(profit_total, "#.##") + " · R:R " + str.tostring(eff_rr, "#.##"),
         color=color.new(i_tp2_color, 20), textcolor=color.white,
         style=is_long ? label.style_label_lower_left : label.style_label_upper_left,
         size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// END
// ─────────────────────────────────────────────────────────────────────────────
