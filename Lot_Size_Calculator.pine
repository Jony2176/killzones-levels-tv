// ═══════════════════════════════════════════════════════════════════════════════
// ██╗      ██████╗ ████████╗    ███████╗██╗███████╗███████╗
// ██║     ██╔═══██╗╚══██╔══╝    ██╔════╝██║╚══███╔╝██╔════╝
// ██║     ██║   ██║   ██║       ███████╗██║  ███╔╝ █████╗
// ██║     ██║   ██║   ██║       ╚════██║██║ ███╔╝  ██╔══╝
// ███████╗╚██████╔╝   ██║       ███████║██║███████╗███████╗
// ╚══════╝ ╚═════╝    ╚═╝       ╚══════╝╚═╝╚══════╝╚══════╝
//         Risk & Lot Size Calculator — Multi-Pair
//          Drag Entry & SL directly on chart
// ═══════════════════════════════════════════════════════════════════════════════

//@version=5
indicator("Risk & Lot Calculator", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS — Trade Parameters (Entry & SL are draggable on chart!)
// ─────────────────────────────────────────────────────────────────────────────

// Dirección del trade
i_direction    = input.string("Long", "Dirección", options=["Long", "Short"], group="📐 Trade Setup")

// Stop Loss en pips — el único dato que siempre ingresás manualmente
i_sl_pips      = input.float(10.0, "Stop Loss (pips)", minval=0.1, step=0.5, group="� Trade Setup", tooltip="Ingresá tus pips de SL. La entrada usa el precio actual automáticamente.")

// Precio de entrada opcional (0 = usa el precio de cierre actual)
i_entry_manual = input.float(0.0, "Precio de Entrada (0 = actual)", step=0.00001, group="📐 Trade Setup", tooltip="Dejá en 0 para usar el precio actual del chart. Útil para órdenes pendientes.")
i_account     = input.float(10000.0, "Balance de Cuenta (USD)", minval=100.0, step=1000.0, group="📐 Trade Setup", tooltip="Balance actual de tu cuenta de fondeo. Ej: 5000, 10000, 25000, 50000, 100000, 200000")
i_risk_pct    = input.float(1.0, "Riesgo (% del balance)", minval=0.1, maxval=10.0, step=0.5, group="📐 Trade Setup", tooltip="Porcentaje del balance a arriesgar. Valores comunes: 0.5%, 1%, 1.5%, 2%")

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS — Risk/Reward & Partials
// ─────────────────────────────────────────────────────────────────────────────

i_rr_tp1       = input.float(2.0, "Ratio TP1 (R:R)", minval=0.5, step=0.5, group="🎯 Targets & Parciales")
i_rr_tp2       = input.float(3.0, "Ratio TP2 (R:R)", minval=1.0, step=0.5, group="🎯 Targets & Parciales")
i_partial_pct  = input.float(80.0, "% a cerrar en TP1", minval=10.0, maxval=100.0, step=5.0, group="🎯 Targets & Parciales", tooltip="Porcentaje del trade a cerrar en TP1. El resto corre hasta TP2.")

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS — Visual
// ─────────────────────────────────────────────────────────────────────────────

i_show_lines   = input.bool(true, "Mostrar líneas SL/TP en chart", group="🎨 Visual")
i_show_boxes   = input.bool(true, "Mostrar zonas de riesgo/ganancia", group="🎨 Visual")
i_show_table   = input.bool(true, "Mostrar tabla resumen", group="🎨 Visual")
i_table_pos    = input.string("Bottom Right", "Posición de tabla", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left", "Middle Right", "Middle Left"], group="🎨 Visual")
i_sl_color     = input.color(#FF1744, "Color SL", group="🎨 Visual")
i_entry_color  = input.color(#B0BEC5, "Color Entrada", group="🎨 Visual")
i_tp1_color    = input.color(#00E676, "Color TP1", group="🎨 Visual")
i_tp2_color    = input.color(#00B0FF, "Color TP2", group="🎨 Visual")
i_extend_bars  = input.int(30, "Extensión de líneas (barras)", minval=5, maxval=100, group="🎨 Visual")

// ─────────────────────────────────────────────────────────────────────────────
// PAIR AUTO-DETECTION — pip size & pip value per instrument
// ─────────────────────────────────────────────────────────────────────────────

is_jpy_pair = str.contains(syminfo.ticker, "JPY")
is_xau      = str.contains(syminfo.ticker, "XAU")

pip_size    = is_jpy_pair ? 0.01 : is_xau ? 0.10 : 0.0001

// Pip value per standard lot (in USD)
pip_value   = is_jpy_pair ? (0.01 / close) * 100000.0 : 10.0

// Price format string adapted per pair
price_fmt   = is_jpy_pair ? "#.###" : is_xau ? "#.##" : "#.#####"

// Pair display name
pair_name   = syminfo.ticker

// ─────────────────────────────────────────────────────────────────────────────
// CORE CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────

// Resolve entry price (use close if not set)
entry_price = i_entry_manual > 0 ? i_entry_manual : close

// Direction from input
is_long    = i_direction == "Long"
dir_mult   = is_long ? 1.0 : -1.0

// SL price derived from entry + pips
sl_price   = entry_price - dir_mult * i_sl_pips * pip_size

// SL in pips (direct from input)
sl_pips    = i_sl_pips

// Risk in USD from account percentage
risk_usd   = i_account * (i_risk_pct / 100.0)

// Lot size: always floor to 1 decimal (never risk more than intended)
lot_size   = sl_pips > 0 ? math.floor(risk_usd / (sl_pips * pip_value) * 10) / 10 : 0.0

// TP prices based on SL distance × ratio
tp1_price  = entry_price + dir_mult * sl_pips * i_rr_tp1 * pip_size
tp2_price  = entry_price + dir_mult * sl_pips * i_rr_tp2 * pip_size

// Partial lots
lots_tp1   = lot_size * (i_partial_pct / 100.0)
lots_tp2   = lot_size * (1.0 - i_partial_pct / 100.0)

// Pips to targets
pips_tp1   = sl_pips * i_rr_tp1
pips_tp2   = sl_pips * i_rr_tp2

// Profit calculations
profit_tp1      = lots_tp1 * pips_tp1 * pip_value
profit_tp2      = lots_tp2 * pips_tp2 * pip_value
profit_total    = profit_tp1 + profit_tp2

// Risk percentage
risk_pct   = (risk_usd / i_account) * 100.0

// Effective R:R (total profit / risk)
eff_rr     = risk_usd > 0 ? profit_total / risk_usd : 0.0

// ─────────────────────────────────────────────────────────────────────────────
// VISUAL — Chart Lines, Labels & Boxes (only on last bar)
// ─────────────────────────────────────────────────────────────────────────────

var line  ln_entry = na
var line  ln_sl    = na
var line  ln_tp1   = na
var line  ln_tp2   = na
var label lb_entry = na
var label lb_sl    = na
var label lb_tp1   = na
var label lb_tp2   = na
var label lb_be    = na
var box   bx_risk  = na
var box   bx_tp1   = na
var box   bx_tp2   = na

if barstate.islast
    // Clean previous drawings
    line.delete(ln_entry)
    line.delete(ln_sl)
    line.delete(ln_tp1)
    line.delete(ln_tp2)
    label.delete(lb_entry)
    label.delete(lb_sl)
    label.delete(lb_tp1)
    label.delete(lb_tp2)
    label.delete(lb_be)
    box.delete(bx_risk)
    box.delete(bx_tp1)
    box.delete(bx_tp2)

    int left_idx  = bar_index - 5
    int right_idx = bar_index + i_extend_bars
    string dir_label = is_long ? "▲ LONG" : "▼ SHORT"

    if i_show_lines
        // ── Entry Line ──
        ln_entry := line.new(left_idx, entry_price, right_idx, entry_price,
             color=i_entry_color, style=line.style_solid, width=2)
        lb_entry := label.new(right_idx, entry_price,
             "ENTRADA: " + str.tostring(entry_price, price_fmt) + " | " + str.tostring(lot_size, "#.##") + " lotes | " + dir_label,
             color=color.new(color.black, 30), textcolor=color.white,
             style=label.style_label_left, size=size.small)

        // ── Stop Loss Line ──
        ln_sl := line.new(left_idx, sl_price, right_idx, sl_price,
             color=i_sl_color, style=line.style_solid, width=2)
        lb_sl := label.new(right_idx, sl_price,
             "SL: " + str.tostring(sl_price, price_fmt) +
             " | -" + str.tostring(sl_pips, "#.#") + "p | -$" + str.tostring(risk_usd, "#.##"),
             color=color.new(i_sl_color, 70), textcolor=color.white,
             style=is_long ? label.style_label_upper_left : label.style_label_lower_left,
             size=size.small)

        // ── TP1 Line (Partial Close) ──
        ln_tp1 := line.new(left_idx, tp1_price, right_idx, tp1_price,
             color=i_tp1_color, style=line.style_dashed, width=2)
        lb_tp1 := label.new(right_idx, tp1_price,
             "TP1 (1:" + str.tostring(i_rr_tp1, "#.#") + "): " + str.tostring(tp1_price, price_fmt) +
             " | +" + str.tostring(pips_tp1, "#.#") + "p | +$" + str.tostring(profit_tp1, "#.##") +
             "\nCerrar " + str.tostring(lots_tp1, "#.##") + " lotes (" + str.tostring(i_partial_pct, "#") + "%)" +
             " → SL a BE (" + str.tostring(entry_price, price_fmt) + ")",
             color=color.new(i_tp1_color, 70), textcolor=color.white,
             style=is_long ? label.style_label_lower_left : label.style_label_upper_left,
             size=size.small)

        // ── TP2 Line (Runner) ──
        ln_tp2 := line.new(left_idx, tp2_price, right_idx, tp2_price,
             color=i_tp2_color, style=line.style_dashed, width=2)
        lb_tp2 := label.new(right_idx, tp2_price,
             "TP2 (1:" + str.tostring(i_rr_tp2, "#.#") + "): " + str.tostring(tp2_price, price_fmt) +
             " | +" + str.tostring(pips_tp2, "#.#") + "p | +$" + str.tostring(profit_tp2, "#.##") +
             "\nMantener " + str.tostring(lots_tp2, "#.##") + " lotes (" + str.tostring(100 - i_partial_pct, "#") + "%)",
             color=color.new(i_tp2_color, 70), textcolor=color.white,
             style=is_long ? label.style_label_lower_left : label.style_label_upper_left,
             size=size.small)

        // ── Breakeven annotation between entry and TP1 ──
        float be_y = (entry_price + tp1_price) / 2.0
        lb_be := label.new(bar_index + math.round(i_extend_bars / 2), be_y,
             "1:" + str.tostring(i_rr_tp1, "#.#") + " → Cerrar " + str.tostring(i_partial_pct, "#") + "% + SL a BE",
             color=color.new(color.white, 100), textcolor=color.new(i_tp1_color, 20),
             style=label.style_none, size=size.normal)

    // ── Colored zones ──
    if i_show_boxes
        float box_top_risk = is_long ? entry_price : sl_price
        float box_bot_risk = is_long ? sl_price : entry_price
        bx_risk := box.new(left_idx, box_top_risk, right_idx, box_bot_risk,
             border_color=color.new(i_sl_color, 80),
             bgcolor=color.new(i_sl_color, 90), border_width=0)

        float box_top_tp1 = is_long ? tp1_price : entry_price
        float box_bot_tp1 = is_long ? entry_price : tp1_price
        bx_tp1 := box.new(left_idx, box_top_tp1, right_idx, box_bot_tp1,
             border_color=color.new(i_tp1_color, 85),
             bgcolor=color.new(i_tp1_color, 92), border_width=0)

        float box_top_tp2 = is_long ? tp2_price : tp1_price
        float box_bot_tp2 = is_long ? tp1_price : tp2_price
        bx_tp2 := box.new(left_idx, box_top_tp2, right_idx, box_bot_tp2,
             border_color=color.new(i_tp2_color, 85),
             bgcolor=color.new(i_tp2_color, 94), border_width=0)

// ─────────────────────────────────────────────────────────────────────────────
// COMPACT SUMMARY TABLE (11 rows — fits all resolutions)
// ─────────────────────────────────────────────────────────────────────────────

if i_show_table and barstate.islast
    string tbl_pos = i_table_pos == "Top Right"    ? position.top_right :
                     i_table_pos == "Top Left"     ? position.top_left :
                     i_table_pos == "Bottom Right"  ? position.bottom_right :
                     i_table_pos == "Bottom Left"   ? position.bottom_left :
                     i_table_pos == "Middle Right"  ? position.middle_right : position.middle_left

    var table tb = table.new(tbl_pos, 2, 11,
         bgcolor=color.new(#1A1A2E, 10),
         border_width=1,
         border_color=color.new(#333355, 40),
         frame_width=2,
         frame_color=color.new(#4444AA, 50))

    color lbl_clr  = color.new(#8888AA, 0)
    color val_clr  = color.new(color.white, 0)
    color sec_clr  = color.new(#4444AA, 30)
    string sz      = size.small
    string dir_text = is_long ? "▲ LONG" : "▼ SHORT"
    color dir_clr   = is_long ? #00E676 : #FF1744

    // Row 0: Header — Pair + Direction
    table.cell(tb, 0, 0, "💰 " + pair_name, text_color=color.white, text_size=sz,
         bgcolor=color.new(#2D2D5E, 0), text_halign=text.align_left)
    table.cell(tb, 1, 0, dir_text, text_color=dir_clr, text_size=sz,
         bgcolor=color.new(#2D2D5E, 0), text_halign=text.align_right)

    // Row 1: Entry + Lots
    table.cell(tb, 0, 1, "Entrada: " + str.tostring(entry_price, price_fmt), text_color=val_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 1, str.tostring(lot_size, "#.##") + " lotes", text_color=val_clr, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // Row 2: SL + Risk
    table.cell(tb, 0, 2, "SL: " + str.tostring(sl_price, price_fmt) + " (" + str.tostring(sl_pips, "#.#") + "p)", text_color=i_sl_color, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 2, "-$" + str.tostring(risk_usd, "#.##") + " (" + str.tostring(risk_pct, "#.##") + "%)", text_color=i_sl_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // Row 3: Separator
    table.cell(tb, 0, 3, "", bgcolor=sec_clr)
    table.cell(tb, 1, 3, "", bgcolor=sec_clr)

    // Row 4: TP1 header
    table.cell(tb, 0, 4, "TP1 (1:" + str.tostring(i_rr_tp1, "#.#") + ")", text_color=i_tp1_color, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 4, str.tostring(tp1_price, price_fmt), text_color=i_tp1_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // Row 5: TP1 lots + profit
    table.cell(tb, 0, 5, "Cerrar " + str.tostring(lots_tp1, "#.##") + " (" + str.tostring(i_partial_pct, "#") + "%)", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 5, "+$" + str.tostring(profit_tp1, "#.##"), text_color=i_tp1_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // Row 6: BE reminder
    table.cell(tb, 0, 6, "→ SL a BE", text_color=#FFD600, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 6, str.tostring(entry_price, price_fmt), text_color=#FFD600, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // Row 7: Separator
    table.cell(tb, 0, 7, "", bgcolor=sec_clr)
    table.cell(tb, 1, 7, "", bgcolor=sec_clr)

    // Row 8: TP2 header
    table.cell(tb, 0, 8, "TP2 (1:" + str.tostring(i_rr_tp2, "#.#") + ")", text_color=i_tp2_color, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 8, str.tostring(tp2_price, price_fmt), text_color=i_tp2_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // Row 9: TP2 lots + profit
    table.cell(tb, 0, 9, "Mantener " + str.tostring(lots_tp2, "#.##") + " (" + str.tostring(100 - i_partial_pct, "#") + "%)", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 9, "+$" + str.tostring(profit_tp2, "#.##"), text_color=i_tp2_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // Row 10: Total
    table.cell(tb, 0, 10, "💎 TOTAL", text_color=color.white, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#2D2D5E, 0))
    table.cell(tb, 1, 10, "+$" + str.tostring(profit_total, "#.##") + " (R:R " + str.tostring(eff_rr, "#.##") + ")", text_color=#00E676, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#2D2D5E, 0))

// ─────────────────────────────────────────────────────────────────────────────
// END
// ─────────────────────────────────────────────────────────────────────────────
