// ═══════════════════════════════════════════════════════════════════════════════
// ██╗      ██████╗ ████████╗    ███████╗██╗███████╗███████╗
// ██║     ██╔═══██╗╚══██╔══╝    ██╔════╝██║╚══███╔╝██╔════╝
// ██║     ██║   ██║   ██║       ███████╗██║  ███╔╝ █████╗
// ██║     ██║   ██║   ██║       ╚════██║██║ ███╔╝  ██╔══╝
// ███████╗╚██████╔╝   ██║       ███████║██║███████╗███████╗
// ╚══════╝ ╚═════╝    ╚═╝       ╚══════╝╚═╝╚══════╝╚══════╝
//            Risk & Lot Size Calculator — EURUSD
//          Partial Close Management + Breakeven SL
// ═══════════════════════════════════════════════════════════════════════════════

//@version=5
indicator("Risk & Lot Calculator", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS — Trade Parameters
// ─────────────────────────────────────────────────────────────────────────────

i_direction   = input.string("Long", "Dirección", options=["Long", "Short"], group="📐 Trade Setup")
i_entry_price = input.float(0.0, "Precio de Entrada (0 = precio actual)", step=0.00001, group="📐 Trade Setup", tooltip="Dejá en 0 para usar el precio de cierre actual")
i_sl_pips     = input.float(10.0, "Stop Loss (pips)", minval=0.1, step=0.5, group="📐 Trade Setup")
i_account     = input.float(10000.0, "Balance de Cuenta (USD)", minval=100.0, step=1000.0, group="📐 Trade Setup", tooltip="Balance actual de tu cuenta de fondeo. Ej: 5000, 10000, 25000, 50000, 100000, 200000")
i_risk_pct    = input.float(1.0, "Riesgo (% del balance)", minval=0.1, maxval=10.0, step=0.5, group="📐 Trade Setup", tooltip="Porcentaje del balance a arriesgar. Valores comunes: 0.5%, 1%, 1.5%, 2%")

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS — Risk/Reward & Partials
// ─────────────────────────────────────────────────────────────────────────────

i_rr_tp1       = input.float(2.0, "Ratio TP1 (R:R)", minval=0.5, step=0.5, group="🎯 Targets & Parciales")
i_rr_tp2       = input.float(3.0, "Ratio TP2 (R:R)", minval=1.0, step=0.5, group="🎯 Targets & Parciales")
i_partial_pct  = input.float(80.0, "% a cerrar en TP1", minval=10.0, maxval=100.0, step=5.0, group="🎯 Targets & Parciales", tooltip="Porcentaje del trade a cerrar en TP1. El resto corre hasta TP2.")

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS — Visual
// ─────────────────────────────────────────────────────────────────────────────

i_show_lines   = input.bool(true, "Mostrar líneas SL/TP en chart", group="🎨 Visual")
i_show_boxes   = input.bool(true, "Mostrar zonas de riesgo/ganancia", group="🎨 Visual")
i_show_table   = input.bool(true, "Mostrar tabla resumen", group="🎨 Visual")
i_table_pos    = input.string("Top Left", "Posición de tabla", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left", "Middle Right", "Middle Left"], group="🎨 Visual")
i_sl_color     = input.color(#FF1744, "Color SL", group="🎨 Visual")
i_entry_color  = input.color(#B0BEC5, "Color Entrada", group="🎨 Visual")
i_tp1_color    = input.color(#00E676, "Color TP1", group="🎨 Visual")
i_tp2_color    = input.color(#00B0FF, "Color TP2", group="🎨 Visual")
i_extend_bars  = input.int(30, "Extensión de líneas (barras)", minval=5, maxval=100, group="🎨 Visual")

// ─────────────────────────────────────────────────────────────────────────────
// CORE CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────

// Pip value for EURUSD: 1 standard lot = $10/pip
pip_size    = 0.0001
pip_value   = 10.0  // USD per pip per standard lot for EURUSD

// Risk in USD from account percentage
i_risk_usd  = i_account * (i_risk_pct / 100.0)

// Entry price
entry_price = i_entry_price > 0 ? i_entry_price : close

// Direction multiplier
is_long    = i_direction == "Long"
dir_mult   = is_long ? 1.0 : -1.0

// Lot size calculation: Risk / (SL_pips × pip_value_per_lot)
lot_size   = i_risk_usd / (i_sl_pips * pip_value)

// Price levels
sl_price   = entry_price - dir_mult * i_sl_pips * pip_size
tp1_price  = entry_price + dir_mult * i_sl_pips * i_rr_tp1 * pip_size
tp2_price  = entry_price + dir_mult * i_sl_pips * i_rr_tp2 * pip_size

// Partial lots
lots_tp1   = lot_size * (i_partial_pct / 100.0)
lots_tp2   = lot_size * (1.0 - i_partial_pct / 100.0)

// Pips to targets
pips_tp1   = i_sl_pips * i_rr_tp1
pips_tp2   = i_sl_pips * i_rr_tp2

// Profit calculations
profit_tp1      = lots_tp1 * pips_tp1 * pip_value
profit_tp2      = lots_tp2 * pips_tp2 * pip_value
profit_total    = profit_tp1 + profit_tp2

// Risk percentage
risk_pct   = (i_risk_usd / i_account) * 100.0

// Effective R:R (total profit / risk)
eff_rr     = profit_total / i_risk_usd

// ─────────────────────────────────────────────────────────────────────────────
// VISUAL — Chart Lines, Labels & Boxes (only on last bar)
// ─────────────────────────────────────────────────────────────────────────────

var line  ln_entry = na
var line  ln_sl    = na
var line  ln_tp1   = na
var line  ln_tp2   = na
var label lb_entry = na
var label lb_sl    = na
var label lb_tp1   = na
var label lb_tp2   = na
var label lb_be    = na
var box   bx_risk  = na
var box   bx_tp1   = na
var box   bx_tp2   = na

if barstate.islast
    // Clean previous drawings
    line.delete(ln_entry)
    line.delete(ln_sl)
    line.delete(ln_tp1)
    line.delete(ln_tp2)
    label.delete(lb_entry)
    label.delete(lb_sl)
    label.delete(lb_tp1)
    label.delete(lb_tp2)
    label.delete(lb_be)
    box.delete(bx_risk)
    box.delete(bx_tp1)
    box.delete(bx_tp2)

    int left_idx  = bar_index - 5
    int right_idx = bar_index + i_extend_bars

    if i_show_lines
        // ── Entry Line ──
        ln_entry := line.new(left_idx, entry_price, right_idx, entry_price,
             color=i_entry_color, style=line.style_solid, width=2)
        lb_entry := label.new(right_idx, entry_price,
             "ENTRADA: " + str.tostring(entry_price, "#.#####") + "\nLotaje: " + str.tostring(lot_size, "#.##") + " lotes",
             color=color.new(color.black, 30), textcolor=i_entry_color,
             style=label.style_label_left, size=size.small)

        // ── Stop Loss Line ──
        ln_sl := line.new(left_idx, sl_price, right_idx, sl_price,
             color=i_sl_color, style=line.style_solid, width=2)
        lb_sl := label.new(right_idx, sl_price,
             "SL: " + str.tostring(sl_price, "#.#####") +
             "\n-" + str.tostring(i_sl_pips, "#.#") + " pips | -$" + str.tostring(i_risk_usd, "#.##"),
             color=color.new(i_sl_color, 70), textcolor=i_sl_color,
             style=is_long ? label.style_label_upper_left : label.style_label_lower_left,
             size=size.small)

        // ── TP1 Line (Partial Close) ──
        ln_tp1 := line.new(left_idx, tp1_price, right_idx, tp1_price,
             color=i_tp1_color, style=line.style_dashed, width=2)
        lb_tp1 := label.new(right_idx, tp1_price,
             "TP1 (1:" + str.tostring(i_rr_tp1, "#.#") + "): " + str.tostring(tp1_price, "#.#####") +
             "\n+" + str.tostring(pips_tp1, "#.#") + " pips | +$" + str.tostring(profit_tp1, "#.##") +
             "\nCerrar " + str.tostring(lots_tp1, "#.##") + " lotes (" + str.tostring(i_partial_pct, "#") + "%)" +
             "\n→ SL a BE (" + str.tostring(entry_price, "#.#####") + ")",
             color=color.new(i_tp1_color, 70), textcolor=i_tp1_color,
             style=is_long ? label.style_label_lower_left : label.style_label_upper_left,
             size=size.small)

        // ── TP2 Line (Runner) ──
        ln_tp2 := line.new(left_idx, tp2_price, right_idx, tp2_price,
             color=i_tp2_color, style=line.style_dashed, width=2)
        lb_tp2 := label.new(right_idx, tp2_price,
             "TP2 (1:" + str.tostring(i_rr_tp2, "#.#") + "): " + str.tostring(tp2_price, "#.#####") +
             "\n+" + str.tostring(pips_tp2, "#.#") + " pips | +$" + str.tostring(profit_tp2, "#.##") +
             "\nMantener " + str.tostring(lots_tp2, "#.##") + " lotes (" + str.tostring(100 - i_partial_pct, "#") + "%)",
             color=color.new(i_tp2_color, 70), textcolor=i_tp2_color,
             style=is_long ? label.style_label_lower_left : label.style_label_upper_left,
             size=size.small)

        // ── Breakeven annotation between entry and TP1 ──
        float be_y = (entry_price + tp1_price) / 2.0
        lb_be := label.new(bar_index + math.round(i_extend_bars / 2), be_y,
             "1:" + str.tostring(i_rr_tp1, "#.#") + " → Cerrar " + str.tostring(i_partial_pct, "#") + "% + SL a BE",
             color=color.new(color.white, 100), textcolor=color.new(i_tp1_color, 20),
             style=label.style_none, size=size.normal)

    // ── Colored zones ──
    if i_show_boxes
        float box_top_risk = is_long ? entry_price : sl_price
        float box_bot_risk = is_long ? sl_price : entry_price
        bx_risk := box.new(left_idx, box_top_risk, right_idx, box_bot_risk,
             border_color=color.new(i_sl_color, 80),
             bgcolor=color.new(i_sl_color, 90), border_width=0)

        float box_top_tp1 = is_long ? tp1_price : entry_price
        float box_bot_tp1 = is_long ? entry_price : tp1_price
        bx_tp1 := box.new(left_idx, box_top_tp1, right_idx, box_bot_tp1,
             border_color=color.new(i_tp1_color, 85),
             bgcolor=color.new(i_tp1_color, 92), border_width=0)

        float box_top_tp2 = is_long ? tp2_price : tp1_price
        float box_bot_tp2 = is_long ? tp1_price : tp2_price
        bx_tp2 := box.new(left_idx, box_top_tp2, right_idx, box_bot_tp2,
             border_color=color.new(i_tp2_color, 85),
             bgcolor=color.new(i_tp2_color, 94), border_width=0)

// ─────────────────────────────────────────────────────────────────────────────
// SUMMARY TABLE
// ─────────────────────────────────────────────────────────────────────────────

if i_show_table and barstate.islast
    string tbl_pos = i_table_pos == "Top Right"    ? position.top_right :
                     i_table_pos == "Top Left"     ? position.top_left :
                     i_table_pos == "Bottom Right"  ? position.bottom_right :
                     i_table_pos == "Bottom Left"   ? position.bottom_left :
                     i_table_pos == "Middle Right"  ? position.middle_right : position.middle_left

    // Table: 2 columns, 16 rows
    var table tb = table.new(tbl_pos, 2, 16,
         bgcolor=color.new(#1A1A2E, 10),
         border_width=1,
         border_color=color.new(#333355, 40),
         frame_width=2,
         frame_color=color.new(#4444AA, 50))

    // ── Header ──
    table.cell(tb, 0, 0, "💰 Risk Calculator", text_color=color.white, text_size=size.small,
         bgcolor=color.new(#2D2D5E, 0), text_halign=text.align_left)
    table.cell(tb, 1, 0, i_direction == "Long" ? "▲ LONG" : "▼ SHORT",
         text_color=is_long ? #00E676 : #FF1744, text_size=size.small,
         bgcolor=color.new(#2D2D5E, 0), text_halign=text.align_right)
    table.merge_cells(tb, 0, 0, 1, 0)

    // Helper: direction text for header
    string dir_text = i_direction == "Long" ? "▲ LONG" : "▼ SHORT"
    color dir_clr   = is_long ? #00E676 : #FF1744

    // ── Trade Info Section ──
    color lbl_clr  = color.new(#8888AA, 0)
    color val_clr  = color.new(color.white, 0)
    color sec_clr  = color.new(#4444AA, 30)
    string sz      = size.small

    table.cell(tb, 0, 1, "Dirección", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 1, dir_text, text_color=dir_clr, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 2, "Entrada", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 2, str.tostring(entry_price, "#.#####"), text_color=val_clr, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 3, "Stop Loss", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 3, str.tostring(sl_price, "#.#####") + " (" + str.tostring(i_sl_pips, "#.#") + "p)", text_color=i_sl_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 4, "Riesgo", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 4, "$" + str.tostring(i_risk_usd, "#.##") + " (" + str.tostring(risk_pct, "#.##") + "%)", text_color=i_sl_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 5, "Lotaje Total", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 5, str.tostring(lot_size, "#.##") + " lotes", text_color=color.new(color.white, 0), text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // ── Separator ──
    table.cell(tb, 0, 6, "", bgcolor=sec_clr)
    table.cell(tb, 1, 6, "", bgcolor=sec_clr)

    // ── TP1 Section ──
    table.cell(tb, 0, 7, "TP1 (1:" + str.tostring(i_rr_tp1, "#.#") + ")", text_color=i_tp1_color, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 7, str.tostring(tp1_price, "#.#####"), text_color=i_tp1_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 8, "Cerrar", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 8, str.tostring(lots_tp1, "#.##") + " lotes (" + str.tostring(i_partial_pct, "#") + "%)", text_color=val_clr, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 9, "Ganancia TP1", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 9, "+$" + str.tostring(profit_tp1, "#.##"), text_color=i_tp1_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 10, "→ SL a BE", text_color=#FFD600, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 10, str.tostring(entry_price, "#.#####"), text_color=#FFD600, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // ── Separator ──
    table.cell(tb, 0, 11, "", bgcolor=sec_clr)
    table.cell(tb, 1, 11, "", bgcolor=sec_clr)

    // ── TP2 Section ──
    table.cell(tb, 0, 12, "TP2 (1:" + str.tostring(i_rr_tp2, "#.#") + ")", text_color=i_tp2_color, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 12, str.tostring(tp2_price, "#.#####"), text_color=i_tp2_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 13, "Mantener", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 13, str.tostring(lots_tp2, "#.##") + " lotes (" + str.tostring(100 - i_partial_pct, "#") + "%)", text_color=val_clr, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    table.cell(tb, 0, 14, "Ganancia TP2", text_color=lbl_clr, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#1A1A2E, 10))
    table.cell(tb, 1, 14, "+$" + str.tostring(profit_tp2, "#.##"), text_color=i_tp2_color, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#1A1A2E, 10))

    // ── Totals ──
    table.cell(tb, 0, 15, "💎 TOTAL", text_color=color.white, text_size=sz, text_halign=text.align_left, bgcolor=color.new(#2D2D5E, 0))
    table.cell(tb, 1, 15, "+$" + str.tostring(profit_total, "#.##") + " (R:R " + str.tostring(eff_rr, "#.##") + ")", text_color=#00E676, text_size=sz, text_halign=text.align_right, bgcolor=color.new(#2D2D5E, 0))

// ─────────────────────────────────────────────────────────────────────────────
// END
// ─────────────────────────────────────────────────────────────────────────────
